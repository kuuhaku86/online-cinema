# Rename this file to .env and fill in your values

# Domain name (used for APP_URL in backend and SSL cert)
DOMAIN=example.com

# JWT secrets — generate with: openssl rand -hex 64
JWT_SECRET=
JWT_REFRESH_SECRET=

# Database password
DB_PASSWORD=

# Frontend output directory (host path where built frontend files go)
FRONTEND_OUTPUT=/var/www/online-cinema/dist
